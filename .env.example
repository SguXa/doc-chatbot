# Application Mode (full|admin|client)
# MODE=full

# Server
# PORT=8080
# HOST=0.0.0.0

# Database
# DATABASE_PATH=/data/aos.db

# Ollama (not used in Phase 1)
# OLLAMA_URL=http://ollama:11434
# OLLAMA_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
# OLLAMA_EMBED_MODEL=bge-m3

# Artemis (not used in Phase 1)
# ARTEMIS_BROKER_URL=tcp://artemis:61616
# ARTEMIS_USER=
# ARTEMIS_PASSWORD=

# Auth (Phase 4+ - not consumed until auth lands, see ADR 0005)
# JWT_SECRET=your-secret-key-minimum-32-characters-long
# ADMIN_PASSWORD=initial-admin-password

# Paths
# DATA_PATH is the base data directory. DOCUMENTS_PATH and IMAGES_PATH
# default to ${DATA_PATH}/documents and ${DATA_PATH}/images respectively
# via HOCON substitution. Override them independently only when ops needs
# to mount documents or images on separate volumes from DATA_PATH.
# DATA_PATH=/data
# DOCUMENTS_PATH=/data/documents
# IMAGES_PATH=/data/images

# Logging
# LOG_LEVEL=INFO
# LOG_FORMAT=text
